{
  "name": "tia-studio",
  "version": "0.3.1",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "i18n:sync": "node ./scripts/sync-locale-files.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:main": "vitest run src/main",
    "ci:release": "npm run lint && npm run typecheck && npm run test && npm run build",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && node ./scripts/run-electron-builder.mjs --dir",
    "build:win": "npm run build && node ./scripts/run-electron-builder.mjs --win",
    "build:mac": "electron-vite build && node ./scripts/run-electron-builder.mjs --mac",
    "build:mac:x64": "electron-vite build && node ./scripts/run-electron-builder.mjs --mac --x64",
    "build:mac:arm64": "electron-vite build && node ./scripts/run-electron-builder.mjs --mac --arm64",
    "build:mac:all": "electron-vite build && node ./scripts/run-electron-builder.mjs --mac --x64 && node ./scripts/run-electron-builder.mjs --mac --arm64",
    "build:linux": "electron-vite build && node ./scripts/run-electron-builder.mjs --linux",
    "verify:libsql-bindings": "node ./scripts/verify-libsql-bindings.mjs",
    "preversion": "npm run ci:release",
    "version:patch": "npm version patch && git push && git push --tags",
    "version:minor": "npm version minor && git push && git push --tags",
    "version:major": "npm version major && git push && git push --tags"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.50",
    "@ai-sdk/google": "^3.0.34",
    "@ai-sdk/openai": "^3.0.37",
    "@ai-sdk/react": "^3.0.107",
    "@assistant-ui/react": "^0.12.14",
    "@assistant-ui/react-ai-sdk": "^1.3.10",
    "@assistant-ui/react-markdown": "^0.12.5",
    "@browserbasehq/stagehand": "^3.1.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@hono/node-server": "^1.19.9",
    "@langchain/openai": "^1.2.13",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@libsql/client": "^0.17.0",
    "@mastra/ai-sdk": "^1.1.0",
    "@mastra/core": "^1.10.0",
    "@mastra/libsql": "^1.6.2",
    "@mastra/mcp": "^1.0.2",
    "@mastra/memory": "^1.5.2",
    "@mcpc-tech/acp-ai-provider": "0.3.0",
    "@openrouter/ai-sdk-provider": "^2.3.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@wecom/aibot-node-sdk": "^1.0.1",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "@xyflow/react": "^12.10.1",
    "ai": "^6.0.105",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.25.1",
    "electron-updater": "^6.3.9",
    "hono": "^4.12.3",
    "i18next": "^25.8.14",
    "lucide-react": "^0.575.0",
    "mdream": "^0.16.0",
    "node-cron": "^4.2.1",
    "ollama-ai-provider": "^1.2.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react-i18next": "^16.5.6",
    "react-mentions": "^4.4.10",
    "react-router-dom": "^7.13.1",
    "react-virtuoso": "^4.14.1",
    "remark-gfm": "^4.0.1",
    "resumable-stream": "2.2.12",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "telegraf": "^4.16.3",
    "wechat-kf-relay": "0.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "optionalDependencies": {
    "@libsql/darwin-arm64": "0.5.22",
    "@libsql/darwin-x64": "0.5.22",
    "@libsql/win32-x64-msvc": "0.5.22"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.19.1",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-mentions": "^4.4.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^28.1.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  }
}
